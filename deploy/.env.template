# =============================================================================
# OpenClaw Docker Deployment - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Generate token: openssl rand -hex 32
# =============================================================================

# --- Required ---
OPENCLAW_CONFIG_DIR=./data
OPENCLAW_WORKSPACE_DIR=./data/workspace
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_RUN_openssl_rand_hex_32
OPENCLAW_GATEWAY_BIND=lan

# --- Port (change if 18789 is already in use) ---
# OPENCLAW_GATEWAY_PORT=18889
# OPENCLAW_BRIDGE_PORT=18890

# --- LLM Provider API Keys (set at least one) ---

# Company LLM (Gauss) via OpenAI-compatible proxy
# GAUSS_PROXY_URL=http://host.docker.internal:8000/v1
# GAUSS_API_KEY=your-company-api-key

# Z.AI (GLM models)
# ZAI_API_KEY=your-zai-api-key

# Google Gemini
# GEMINI_API_KEY=your-gemini-api-key

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
